// =============================================================================
//  accounts.example.json — TEMPLATE (rename to accounts.json, edit, run bot)
// =============================================================================
//  Butuh setup cepet?    $ cp accounts.example.json accounts.json
//                        $ npm run add-account    (wizard, paste wallet aman)
//
//  Format: JSON5 (// comments + trailing commas OK).
//  4 field wajib: name, wallet, proxy, enabled. Sisanya ada default sane.
//  Lihat README.md bagian "Configuration" untuk semua field advanced.
// =============================================================================

[
  {
    "name": "main",                                   // bebas, harus unik
    "wallet": "",                                     // paste private key Phantom
    "proxy": null,                                    // null = direct | "socks5://..." | "http://..."
    "enabled": true,
    "castModes": ["magnet", "meme"],                    // ARRAY — bot does each per cycle
                                                     // allowed: "magnet", "meme" (+ "rod" alias)
                                                     // 1 mode   = ["magnet"]        (magnet only)
                                                     // 2 modes  = ["magnet", "meme"] (magnet first, then paid meme)
                                                     // meme-only = ["meme"]          (paid only, no magnet)

    // ── Advanced (uncomment untuk aktifin) ──────────────────────────────
    // "claimGrants": true,                            // klaim daily grant pas login
    // "sellMode": "auto",                             // "auto" | "threshold" | "off"
    // "sellThreshold": 50,                            // ikan disimpan sebelum dijual
    // "memeMode": "off",                              // "off" | "parallel" | "sequential"
    // "character": {
    //   "mode": "skip",                               // "skip" | "config" | "auto"
    //   "boat": "tugboat",                            // lihat lib/character.js
    //   "hull": "#a9743f",                            // warna hull  #RRGGBB
    //   "accent": "#7fd4e8"                           // warna accent #RRGGBB
    // }
  }

  // Tambah akun ke-2:  paste blok di atas, ganti "name" + "wallet".
  // Atau pake wizard:  $ npm run add-account
]