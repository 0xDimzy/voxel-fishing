{
  "name": "voxelfishing-bot",
  "version": "3.0.0",
  "type": "module",
  "description": "VoxelFishing bot — simple multi-account (per-akun proxy, cast/sell loop), Privy SIWS sign-in, humanized timing.",
  "main": "bot.js",
  "scripts": {
    "start": "node bot.js",
    "start:v2": "node bot-v2.js",
    "auth": "node bot.js --auth-only",
    "auth:v2": "node bot-v2.js --auth-only",
    "once": "node bot.js --once",
    "account": "node bot.js --account",
    "// accounts": "────────── multi-account helpers ──────────",
    "accounts": "node scripts/list-accounts.js",
    "add-account": "node scripts/add-account.js",
    "edit-account": "node scripts/edit-account.js",
    "remove-account": "node scripts/remove-account.js",
    "enable": "node scripts/toggle-account.js --enable",
    "disable": "node scripts/toggle-account.js --disable",
    "toggle": "node scripts/toggle-account.js",
    "setup": "node scripts/setup-wizard.js"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "bs58": "^5.0.0",
    "chalk": "^5.6.2",
    "dotenv": "^16.4.5",
    "https-proxy-agent": "^7.0.5",
    "json5": "^2.2.3",
    "jsonc-parser": "^3.3.1",
    "socks-proxy-agent": "^10.1.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "undici": "^6.19.0",
    "ws": "^8.18.0"
  }
}